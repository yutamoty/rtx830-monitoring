# SNMP Exporter Configuration for YAMAHA RTX830
# Prometheus SNMP Exporter v0.23.0+ 形式
#
# 使用方法:
#   1. このファイルをコピー: cp snmp-exporter/snmp.yml.example snmp-exporter/snmp.yml
#   2. auths.public_v2.community の値をRTX830で設定したCommunity Stringに変更
#   3. docker-compose up -d で起動

# 認証設定（v0.23.0から分離された）
auths:
  public_v2:
    community: public  # ⚠️ RTX830で設定したCommunity Stringに変更してください
    version: 2  # SNMPv2c

# モジュール定義
modules:
  rtx830:
    walk:
      - 1.3.6.1.2.1.1
      - 1.3.6.1.2.1.2
      - 1.3.6.1.2.1.4
      - 1.3.6.1.2.1.5
      - 1.3.6.1.2.1.6
      - 1.3.6.1.2.1.7
      - 1.3.6.1.2.1.25.2.3
      - 1.3.6.1.2.1.25.3.3
      - 1.3.6.1.2.1.31.1.1
