# RTX830 SNMP設定
# RTX830のIPアドレスまたはホスト名
RTX830_HOST=192.168.1.1

# SNMP Community String（SNMPv2c使用時）
# セキュリティのため、デフォルトの"public"から変更することを推奨
SNMP_COMMUNITY=public

# SNMPバージョン (2c または 3)
SNMP_VERSION=2c

# Grafana設定
# Grafana管理者パスワード
# 初回ログイン後、必ず変更してください
GRAFANA_ADMIN_PASSWORD=admin

# Grafanaアクセスポート
GRAFANA_PORT=3000

# Prometheus設定
# Prometheusアクセスポート
PROMETHEUS_PORT=9090

# データ保持期間（例: 15d=15日, 30d=30日, 1y=1年）
PROMETHEUS_RETENTION=15d

# SNMP Exporter設定
# SNMP Exporterアクセスポート
SNMP_EXPORTER_PORT=9116

# タイムゾーン設定（オプション）
TZ=Asia/Tokyo
