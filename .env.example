# RTX830 SNMP設定
# RTX830のIPアドレスまたはホスト名
RTX830_HOST=192.168.1.1

# ⚠️ SNMP_COMMUNITYは現在未使用です
# Community Stringは alloy/snmp.yml に直接記述してください
# （Alloyは環境変数での置換をサポートしていません）
SNMP_COMMUNITY=public

# SNMPバージョン (2c または 3)
SNMP_VERSION=2c

# ========================================
# Grafana Cloud設定
# ========================================

# Grafana Cloud PrometheusエンドポイントURL
# 取得方法: Grafana Cloud → Connections → Add new connection → Hosted Prometheus metrics
# 例: https://prometheus-prod-xx-xxx-xxx.grafana.net/api/prom/push
GRAFANA_CLOUD_PROMETHEUS_URL=https://prometheus-prod-xx-xxx-xxx.grafana.net/api/prom/push

# Grafana Cloud Prometheusユーザー名
# 通常は数字のみ（例: 123456）
GRAFANA_CLOUD_PROMETHEUS_USER=123456

# Grafana Cloud APIキー
# 取得方法: Grafana Cloud → Security → API Keys → Create API Key
# 権限: MetricsPublisher または Admin
GRAFANA_CLOUD_API_KEY=glc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================================
# Grafana Alloy設定
# ========================================

# Alloy管理UIポート（ブラウザでアクセス可能）
# http://<Raspberry_PiのIP>:12345 でアクセス可能
ALLOY_PORT=12345

# ========================================
# その他の設定
# ========================================

# タイムゾーン設定（オプション）
TZ=Asia/Tokyo
