          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus"},
          "expr": "- (rate(ifHCOutOctets{device=\"rtx830\", ifDescr=~\"$interface\"}[5m]) * 8 and on(ifIndex, instance) (ifOperStatus{device=\"rtx830\"} == 1))",
          "legendFormat": "{{ifDescr}} Out",
          "refId": "B"
        }
