    {
      "datasource": {"type": "prometheus"},
      "title": "System Uptime",
      "type": "stat",
      "id": 1,
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "sysUpTime{device=\"rtx830\"} / 100",
          "refId": "A"
        }
      ]
    },
